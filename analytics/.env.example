# ── Analytics dashboard config (all optional; sane defaults provided) ──────────

# Port the local dashboard listens on.
ANALYTICS_PORT=4100

# Directory holding the bot's paper PnL history JSON files.
# Defaults to ../logs/paper relative to the analytics folder.
# PAPER_LOG_DIR=/absolute/path/to/logs/paper

# Ignore markets settled before this ET date so stale historical runs don't
# pollute the numbers. Defaults to TODAY. Use a YYYY-MM-DD date to include older
# data, or "all" to show everything.
# ANALYTICS_SINCE_DATE=2026-06-21

# ── Cloudflare tunnel ─────────────────────────────────────────────────────────
# Set to true to disable the public tunnel (local-only).
DISABLE_CLOUDFLARE_TUNNEL=false
# How long (minutes) before proactively rotating the quick tunnel. trycloudflare
# quick tunnels are unstable; rotating keeps the link fresh. 0 = only rotate on crash.
TUNNEL_ROTATE_MINUTES=0

# ── Telegram (auto-sends the rotating dashboard link) ─────────────────────────
# Leave blank to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI analysis (optional) ────────────────────────────────────────────────────
# When set, the "Analyze with AI" button calls Claude. Without it, the dashboard
# falls back to the built-in heuristic analysis (no API key required).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
