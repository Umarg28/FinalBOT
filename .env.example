# ===========================================
# LIGHTEDGE POLYMARKET BOT CONFIGURATION
# ===========================================

# Trading Mode (set to "true" for paper trading, "false" for live)
PAPER_MODE=true

# ===========================================
# UNIFIED LAUNCHER (npm run start)
# ===========================================
# `npm run start` launches the bot AND the analytics dashboard together.
# Set to false to run the bot alone.
START_ANALYTICS=true

# ===========================================
# TELEGRAM ALERTS (anti-spam controls)
# ===========================================
# Master switch for all bot alerts.
TELEGRAM_ALERTS_ENABLED=true
# Noisy "warning" alerts (price delays, market skips, missing markets) are OFF by
# default to stop spam. Set true to re-enable them.
TELEGRAM_WARNINGS_ENABLED=false
# Minimum ms between alerts of the same kind (default 5 min).
TELEGRAM_MIN_INTERVAL_MS=300000
# Hard cap: minimum ms between ANY two alerts (default 60s).
TELEGRAM_GLOBAL_MIN_INTERVAL_MS=60000

# ===========================================
# WALLET CONFIGURATION
# ===========================================
# Your main wallet address
USER_ADDRESS=

# Proxy wallet address (for Polymarket operations)
PROXY_WALLET=

# Private key for signing transactions (KEEP SECRET!)
PRIVATE_KEY=

# ===========================================
# POLYMARKET API ENDPOINTS
# ===========================================
CLOB_HTTP_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Official Polymarket real-time data client.
# Runs alongside the legacy CLOB websocket used by the dashboard.
ENABLE_OFFICIAL_REALTIME=true
OFFICIAL_REALTIME_DEBUG=false
OFFICIAL_REALTIME_REFRESH_MS=30000

# ===========================================
# BLOCKCHAIN CONFIGURATION
# ===========================================
# Polygon RPC URL
RPC_URL=https://polygon-rpc.com

# USDC.e Contract Address on Polygon (bridged USDC used by Polymarket CTF)
USDC_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# Live wallet readiness checks.
MIN_MATIC_BALANCE=0.05
MIN_USDCE_BALANCE=1
# If true, live startup fails when CTF/CLOB approvals are missing.
# Leave false if you only want warnings while testing.
REQUIRE_TRADING_APPROVALS=false

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
MONGO_URI=mongodb://localhost:27017/lightedge_polymarket

# ===========================================
# BOT SETTINGS
# ===========================================
# How often to fetch market data (in seconds)
FETCH_INTERVAL=5

# Maximum age of trades to consider (in hours)
TOO_OLD_TIMESTAMP=24

# Number of retry attempts for failed orders
RETRY_LIMIT=3

# ===========================================
# PAPER TRADING SETTINGS
# ===========================================
# Starting balance for paper trading (in USDC)
PAPER_BALANCE=10000

# ===========================================
# STRATEGY SETTINGS (for your custom strategies)
# ===========================================
# Add your own strategy parameters here
# Example:
# MAX_POSITION_SIZE=1000
# STOP_LOSS_PERCENT=5
# TAKE_PROFIT_PERCENT=10
