{
  "name": "lightedge-polymarket-bot",
  "version": "1.0.0",
  "description": "Polymarket trading bot with paper trading mode and customizable strategies",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "ts-node src/index.ts",
    "paper": "cross-env PAPER_MODE=true ts-node src/index.ts",
    "watcher": "cross-env WATCHER_MODE=true PAPER_MODE=true ts-node src/index.ts",
    "watcher:dashboard": "cross-env WATCHER_MODE=true PAPER_MODE=true ts-node src/index.ts",
    "profits": "ts-node src/scripts/profitTelegramReporter.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "start:all": "bash run-all-bots.sh",
    "multi": "bash run-dashboard.sh",
    "monitor": "bash monitor-bots.sh"
  },
  "keywords": [
    "polymarket",
    "trading",
    "bot",
    "paper-trading"
  ],
  "license": "ISC",
  "dependencies": {
    "@catalyst-team/poly-sdk": "^0.3.0",
    "@polymarket/clob-client": "^4.4.3",
    "@types/js-yaml": "^4.0.9",
    "@types/ws": "^8.5.13",
    "axios": "^1.7.7",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.5",
    "ethers": "^5.7.2",
    "js-yaml": "^4.1.1",
    "moment": "^2.30.1",
    "mongoose": "^8.8.0",
    "ora": "^5.4.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "wrangler": "^4.59.0"
  }
}
